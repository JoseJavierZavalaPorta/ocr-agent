# Datos y volúmenes (generados en runtime)
volumes/input/*
volumes/output/*
volumes/originals/*
volumes/db/*
volumes/redis/*
volumes/models/*
!volumes/input/.gitkeep
!volumes/output/.gitkeep
!volumes/originals/.gitkeep
!volumes/db/.gitkeep
!volumes/redis/.gitkeep
!volumes/models/.gitkeep
!volumes/models/ollama/.gitkeep
!volumes/models/huggingface/.gitkeep

# Configuración con secretos (usar .env.example como plantilla)
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
*.log

# Frontend
node_modules/
frontend/dist/
frontend/.vite/

# Varios
*.tmp
.DS_Store
.claude/
