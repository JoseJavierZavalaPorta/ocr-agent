# ============================================================
# OCR Agent — Variables de Entorno
# Copia este archivo a .env y ajusta según tu entorno
# ============================================================

# --- GPU AMD (ROCm) ---
# GFX version de tu GPU. Para RX 5090 (RDNA4) usar 12.0.0
# Para RX 7900 XTX usar 11.0.0, para RX 6900 XT usar 10.3.0
# Dejar vacío para detección automática (puede fallar en GPUs nuevas)
HSA_OVERRIDE_GFX_VERSION=12.0.0
ROCR_VISIBLE_DEVICES=0

# --- Pipeline OCR ---
# Umbral de confianza para marcar página como PASSED (0.0-1.0)
CONFIDENCE_THRESHOLD_PASS=0.80
# Umbral para WARNING (por debajo de PASS, por encima de ERROR)
CONFIDENCE_THRESHOLD_WARN=0.60
# Score de handwriting para rutear a TrOCR (0.0-1.0)
HANDWRITING_THRESHOLD=0.60
# Score de complejidad de layout para rutear a MinerU (0.0-1.0)
LAYOUT_COMPLEXITY_THRESHOLD=0.40

# --- Procesamiento ---
# Máximo de workers Celery concurrentes
CELERY_CONCURRENCY=2
# DPI para extracción de imágenes de PDFs (mínimo 300, recomendado 400)
PDF_EXTRACTION_DPI=400
# Tamaño de batch para procesamiento de páginas con Surya
SURYA_BATCH_SIZE=8

# --- Modelos Ollama ---
# Modelo para corrección de texto
OLLAMA_CORRECTION_MODEL=llama3.1:8b
# Modelo para routing/clasificación (dejar vacío para usar heurísticas)
OLLAMA_ROUTING_MODEL=

# --- Rutas (ajustar si usas NFS/SMB) ---
# Estas rutas son DENTRO del container Docker
# Los volúmenes se mapean en docker-compose.yml
INPUT_PATH=/data/input
OUTPUT_PATH=/data/output
ORIGINALS_PATH=/data/originals
MODELS_PATH=/data/models

# --- Seguridad ---
# Token para API (cambiar en producción)
API_SECRET_KEY=cambiar-en-produccion-secret-key-aleatoria
