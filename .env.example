# ============================================================
# OCR Agent — Plantilla de Variables de Entorno
# Copia este archivo como .env y ajusta los valores:
#   cp .env.example .env
# ============================================================

# --- Pipeline OCR ---
CONFIDENCE_THRESHOLD_PASS=0.80
CONFIDENCE_THRESHOLD_WARN=0.60
HANDWRITING_THRESHOLD=0.85
LAYOUT_COMPLEXITY_THRESHOLD=0.25

# --- Procesamiento ---
CELERY_CONCURRENCY=2
PDF_EXTRACTION_DPI=200
SURYA_BATCH_SIZE=8

# --- Modelos Ollama ---
# qwen2.5:32b: ~19 GB — correccion LLM para todo tipo de documento
# minicpm-v:   ~5.5 GB — Vision OCR para manuscritos y formularios escaneados
OLLAMA_CORRECTION_MODEL=qwen2.5:32b
OLLAMA_VISION_MODEL=minicpm-v

# --- AMD ROCm (GPU AMD para Ollama) ---
# Consultar version gfx con: rocminfo | grep gfx
# Ejemplos: RX 6000 serie -> 10.3.0 | RX 7000 serie -> 11.0.0 | RX 9000 serie -> 12.0.0
HSA_OVERRIDE_GFX_VERSION=11.0.0
ROCR_VISIBLE_DEVICES=0
# Nombre de la GPU para el dashboard (texto libre, opcional)
SYSTEM_GPU_NAME=

# --- Seguridad ---
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=cambiar-en-produccion-secret-key-aleatoria
